---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-linear-to-br from-slate-50 to-white py-10">
  <div class="container mx-auto px-6">
    <div class="grid gap-10 md:grid-cols-4">
      <!-- Company Info -->
      <div>
        <h2 class="text-xl font-bold text-slate-800 mb-3">MONE TAB LIMITED</h2>
        <p class="text-sm text-slate-600 leading-relaxed">
          Providing premium quality products across personal care, beverages, and more — trusted by professionals and consumers alike.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-semibold text-slate-800 mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm text-slate-600">
          <li><a href="/" class="hover:text-blue-600 transition">Home</a></li>
          <li><a href="/about" class="hover:text-blue-600 transition">About Us</a></li>
          <li><a href="/products" class="hover:text-blue-600 transition">Product Catalog</a></li>
          <li><a href="/contact" class="hover:text-blue-600 transition">Contact</a></li>
          <!-- Privacy Policy -->
          <li><a href="/privacy" class="hover:text-blue-600 transition">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-blue-600 transition">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h3 class="text-lg font-semibold text-slate-800 mb-3">Our Categories</h3>
        <ul class="space-y-2 text-sm text-slate-600">
          <li><a href="/products#personal-care" class="hover:text-blue-600 transition">Personal Care</a></li>
          <li><a href="/products#beverages" class="hover:text-blue-600 transition">Beverages</a></li>
          <li><a href="/products#confectionery" class="hover:text-blue-600 transition">Confectionery</a></li>
          <li><a href="/products#kitchenware" class="hover:text-blue-600 transition">Kitchenware</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-semibold text-slate-800 mb-3">Contact Us</h3>
        <ul class="text-sm text-slate-600 space-y-2">
          <li>📍 3rd Floor Belmont Road, Uxbridge, England, UB8 1HE</li>
          <li>✉️ info@monetabltd.com</li>
          <li>🌐 <a href="https://monetabltd.com/" class="hover:text-blue-600 transition">monetabltd.com</a></li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="my-8 border-t border-slate-200"></div>

    <!-- Bottom bar -->
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-slate-500">&copy; {year} MONE TAB LIMITED. All rights reserved.</p>

      <p class="text-sm text-slate-500">
        Designed & Developed by 
        <a href="https://thewebpal.com" target="_blank" rel="noopener noreferrer" 
           class="ml-1 font-semibold text-blue-600 hover:text-blue-700 transition">
          THEWEBPAL
        </a>
      </p>
    </div>
  </div>
</footer>
