---
import Layout from '../layouts/Layout.astro';

const values = [
  { icon: "fa-star", title: "Uncompromising Quality", description: "We source and supply only products that we would be proud to use in our own homes, ensuring excellence in every item." },
  { icon: "fa-handshake", title: "True Partnership", description: "We believe in collaborative success. Your growth is our growth, and we are dedicated to providing the support you need." },
  { icon: "fa-truck-fast", title: "Dependable Service", description: "From streamlined ordering to reliable, on-time delivery, we are committed to making your experience seamless and efficient." },
  { icon: "fa-lightbulb", title: "Continuous Improvement", description: "We constantly adapt to market trends and listen to client feedback to ensure our product range is always relevant and competitive." },
];

const stats = [
  { value: "500+", label: "Active Partners" },
  { value: "1000+", label: "Products" },
  { value: "15+", label: "Years Experience" },
  { value: "98%", label: "Satisfaction" },
];
---

<Layout title="About Us | MONE TAB LIMITED">

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-cyan-950 to-slate-900 text-white py-24 overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-cyan-500/20 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-cyan-500/15 rounded-full blur-[150px]"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-block bg-cyan-500/20 border border-cyan-400/30 text-cyan-300 text-sm font-semibold px-4 py-1.5 rounded-full mb-6">About Us</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6">
          Building the Future of
          <span class="block bg-gradient-to-r from-cyan-400 to-cyan-200 bg-clip-text text-transparent">Wholesale, Together</span>
        </h1>
        <p class="text-xl text-cyan-200 leading-relaxed max-w-2xl mx-auto">
          MONE TAB LIMITED is more than a supplier; we are your strategic partner in growth, committed to providing outstanding products, responsive service, and wholesale solutions you can rely on.
        </p>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0">
      <svg class="w-full h-16 text-white" viewBox="0 0 1440 60" preserveAspectRatio="none">
        <path d="M0,40 C480,80 960,0 1440,40 L1440,60 L0,60 Z" class="fill-current"/>
      </svg>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 bg-white border-b border-gray-100">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-black text-cyan-800 mb-1">{stat.value}</div>
            <div class="text-gray-600 font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Story Section -->
  <section class="py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-cyan-200 to-cyan-100 rounded-3xl blur-2xl opacity-50"></div>
          <div class="relative">
            <img 
              src="/15.jpg" 
              alt="MONE TAB LIMITED warehouse operations" 
              class="rounded-2xl shadow-2xl w-full"
              loading="lazy"
            />
            <div class="absolute -bottom-6 -right-6 bg-white rounded-xl shadow-xl p-4 border border-gray-100">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-cyan-600 rounded-full flex items-center justify-center">
                  <i class="fas fa-award text-white text-xl"></i>
                </div>
                <div>
                  <div class="font-bold text-gray-900">15+ Years</div>
                  <div class="text-sm text-gray-500">Industry Experience</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div>
          <span class="inline-block bg-cyan-100 text-cyan-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-4">Our Story</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            From a Simple Idea to a Trusted Partner
          </h2>
          <p class="text-lg text-gray-600 leading-relaxed mb-4">
            Founded on the principle of bridging the gap between quality manufacturers and discerning retailers, MONE TAB LIMITED started with a simple mission: to make high-quality household goods accessible to businesses of all sizes.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed mb-6">
            Today, we have grown into a leading wholesale provider in the UK, but our core values remain unchanged. Our success is built on the strong, lasting relationships we forge with our clients.
          </p>
          <div class="flex flex-wrap gap-4">
            <div class="flex items-center gap-2 text-gray-700">
              <i class="fas fa-check-circle text-green-500"></i>
              <span>UK-Based Company</span>
            </div>
            <div class="flex items-center gap-2 text-gray-700">
              <i class="fas fa-check-circle text-green-500"></i>
              <span>Nationwide Delivery</span>
            </div>
            <div class="flex items-center gap-2 text-gray-700">
              <i class="fas fa-check-circle text-green-500"></i>
              <span>Quality Assured</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Values Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <span class="inline-block bg-green-100 text-green-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-4">Our Values</span>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">The Principles That Guide Us</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">Our commitment to these core values ensures we deliver excellence in every aspect of our business.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((value, index) => (
          <div class="group bg-white rounded-2xl p-8 shadow-lg border border-gray-100 hover:shadow-2xl hover:border-cyan-200 transition-all duration-500 hover:-translate-y-2 text-center">
            <div class="w-16 h-16 bg-gradient-to-br from-cyan-500 to-cyan-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg shadow-cyan-500/30 group-hover:scale-110 transition-transform duration-300">
              <i class={`fas ${value.icon} text-2xl text-white`}></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{value.title}</h3>
            <p class="text-gray-600 leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative bg-gradient-to-br from-slate-950 via-cyan-900 to-slate-900 text-white py-24 overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-0 w-[400px] h-[400px] bg-cyan-500/20 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-cyan-500/20 rounded-full blur-[150px]"></div>
    <div class="container mx-auto px-4 text-center relative z-10">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Let's Work Together</h2>
      <p class="text-xl text-cyan-200 mb-10 max-w-2xl mx-auto leading-relaxed">
        Discover how our products and services can benefit your business. Explore our catalog or get in touch with our team today.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/products" class="inline-flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white px-8 py-4 rounded-xl font-bold transition-all duration-300 hover:-translate-y-0.5 shadow-lg">
          <i class="fas fa-box"></i>
          View Our Products
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-100 text-cyan-800 px-8 py-4 rounded-xl font-bold transition-all duration-300 hover:-translate-y-0.5 shadow-lg">
          <i class="fas fa-envelope"></i>
          Contact Our Team
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>