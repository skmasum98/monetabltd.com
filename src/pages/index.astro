---
import Layout from '../layouts/Layout.astro';

const stats = [
  { value: "500+", label: "Active Partners", icon: "fa-handshake" },
  { value: "1000+", label: "Products Available", icon: "fa-boxes-stacked" },
  { value: "15+", label: "Years Experience", icon: "fa-award" },
  { value: "98%", label: "Client Satisfaction", icon: "fa-star" }
];

const categories = [
  { name: "Personal Care", icon: "fa-pump-soap", color: "from-blue-500 to-blue-600", desc: "Premium skincare, haircare & hygiene products", image: "/1.jpg" },
  { name: "Beverages", icon: "fa-wine-bottle", color: "from-green-500 to-green-600", desc: "Quality drinks for retail & hospitality", image: "/2.jpg" },
  { name: "Household Goods", icon: "fa-house", color: "from-amber-500 to-amber-600", desc: "Cleaning supplies & home essentials", image: "/3.jpg" },
  { name: "Confectionery", icon: "fa-cookie", color: "from-red-500 to-red-600", desc: "Chocolates, biscuits & sweet treats", image: "/4.jpg" },
  { name: "Health & Wellness", icon: "fa-heart-pulse", color: "from-emerald-500 to-emerald-600", desc: "Vitamins, supplements & wellness", image: "/9.jpg" },
  { name: "Baby Care", icon: "fa-baby", color: "from-pink-500 to-pink-600", desc: "Gentle products for babies & children", image: "/10.jpg" }
];

const trustPoints = [
  { title: "Premium Quality", desc: "Sourced from reputable manufacturers", icon: "certificate" },
  { title: "Next-Day Delivery", desc: "Fast, reliable nationwide shipping", icon: "truck-fast" },
  { title: "Competitive Pricing", desc: "Volume discounts available", icon: "tags" },
  { title: "Dedicated Support", desc: "Personal account manager assigned", icon: "headset" },
  { title: "Flexible Payment", desc: "Net terms for approved accounts", icon: "credit-card" }
];

const processSteps = [
  { num: "01", title: "Create Account", desc: "Register your business and get verified" },
  { num: "02", title: "Browse Catalog", desc: "Explore our full product range" },
  { num: "03", title: "Place Order", desc: "Order via account manager or online" },
  { num: "04", title: "Receive Delivery", desc: "Fast delivery to your doorstep" }
];
