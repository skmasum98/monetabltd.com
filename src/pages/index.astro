              <span>Premium Quality</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-blue-200">
              <i class="fas fa-check-circle text-cyan-400"></i>
              <span>UK Wide Delivery</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-blue-200">
              <i class="fas fa-check-circle text-cyan-400"></i>
              <span>Competitive Prices</span>
            </div>
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div class="absolute inset-0 bg-linear-to-br from-cyan-500/20 to-blue-600/20 rounded-3xl blur-2xl"></div>
          <div class="relative grid grid-cols-2 gap-4">
            <div class="space-y-4">
