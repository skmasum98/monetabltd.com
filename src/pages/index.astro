              <span>Explore Products</span>
              <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </a>
            <a href="#contact" class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white px-8 py-4 rounded-xl font-bold hover:bg-white/20 transition-all duration-300 hover:-translate-y-0.5">
              <i class="fas fa-phone"></i>
              <span>Contact Us</span>
            </a>
          </div>

