---
import Layout from '../layouts/Layout.astro';

const sections = [
  {
    title: "Information We Collect",
    icon: "fa-info-circle",
    content: [
      "As a static business website, we limit data collection to what is strictly necessary for business communication and analytics.",
      "When you submit an inquiry through our contact form, we collect: Your Name, Company Name (if provided), Email Address, Phone Number (if provided), and Message Content."
    ]
  },
  {
    title: "How We Use Your Information",
    icon: "fa-check-circle",
    content: [
      "To respond to your inquiries and provide you with requested quotes or information.",
      "To manage our customer and potential client relationships.",
      "For internal record-keeping and business analysis."
    ]
  },
  {
    title: "Data Retention and Security",
    icon: "fa-shield-halved",
    content: [
      "We retain your personal data only for as long as necessary to fulfill the purposes for which it was collected.",
      "We take reasonable steps to protect the personal information we hold from misuse, loss, unauthorized access, modification, or disclosure."
    ]
  },
  {
    title: "Your Rights (GDPR)",
    icon: "fa-user-shield",
    content: [
      "The right to access, update or delete the personal information we have on you.",
      "The right of rectification, right to object, right of restriction.",
      "The right to data portability and right to withdraw consent."
    ],
    cta: { href: "mailto:info@monetabltd.com", text: "info@monetabltd.com" }
  },
  {
    title: "Changes to This Policy",
    icon: "fa-clock",
    content: [
      "We may update our Privacy Policy from time to time. We will notify you of any changes by posting the new Privacy Policy on this page."
    ]
  }
];
---

<Layout title="Privacy Policy | MONE TAB LIMITED">

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-cyan-950 to-slate-900 text-white py-24 overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-cyan-500/20 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-cyan-500/15 rounded-full blur-[150px]"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-block bg-cyan-500/20 border border-cyan-400/30 text-cyan-300 text-sm font-semibold px-4 py-1.5 rounded-full mb-6">Legal</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6">
          Privacy
          <span class="bg-gradient-to-r from-cyan-400 to-cyan-500 bg-clip-text text-transparent">Policy</span>
        </h1>
        <p class="text-xl text-cyan-200 leading-relaxed max-w-2xl mx-auto">
          MONE TAB LIMITED is committed to protecting the privacy of visitors to our website. This policy explains how we handle the personal data you provide to us.
        </p>
        <p class="mt-4 text-sm text-cyan-300">Last Updated: April 28, 2026</p>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0">
      <svg class="w-full h-16 text-white" viewBox="0 0 1440 60" preserveAspectRatio="none">
        <path d="M0,40 C480,80 960,0 1440,40 L1440,60 L0,60 Z" class="fill-current"/>
      </svg>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        {sections.map((section, index) => (
          <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-8 hover:shadow-xl hover:border-cyan-200 transition-all duration-300">
            <div class="flex items-start gap-5">
              <div class="w-14 h-14 bg-gradient-to-br from-cyan-500 to-cyan-600 rounded-xl flex items-center justify-center shadow-lg shrink-0">
                <i class={`fas ${section.icon} text-xl text-white`}></i>
              </div>
              <div class="flex-1">
                <h2 class="text-2xl font-bold text-gray-900 mb-4">{section.title}</h2>
                {section.content.map((paragraph) => (
                  <p class="text-gray-600 leading-relaxed mb-3">{paragraph}</p>
                ))}
                {section.cta && (
                  <div class="mt-4 p-4 bg-cyan-50 rounded-xl">
                    <p class="text-gray-700 mb-2">To exercise any of these rights, please contact us at:</p>
                    <a href={section.cta.href} class="inline-flex items-center font-semibold text-cyan-600 hover:text-cyan-800 transition-colors">
                      <i class="fas fa-envelope mr-2"></i>
                      {section.cta.text}
                    </a>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}

        <!-- Contact Card -->
        <div class="bg-gradient-to-br from-cyan-800 to-cyan-900 rounded-2xl p-8 text-white text-center">
          <h2 class="text-2xl font-bold mb-4">Questions About Our Privacy Policy?</h2>
          <p class="text-cyan-200 mb-6">We're here to help with any questions you may have about how we handle your data.</p>
          <a href="/contact" class="inline-flex items-center gap-2 bg-white text-cyan-900 px-6 py-3 rounded-xl font-bold hover:bg-cyan-50 transition-all duration-300">
            <i class="fas fa-envelope"></i>
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>