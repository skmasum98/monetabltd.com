---
import Layout from '../layouts/Layout.astro';

const coreServices = [
  {
    icon: "fa-boxes-stacked",
    title: "Wholesale Product Supply",
    description: "Our primary service is providing reliable, bulk access to a curated catalog of high-quality household goods, personal care items, beverages, and more.",
    color: "from-cyan-500 to-cyan-600"
  },
  {
    icon: "fa-user-tie",
    title: "Dedicated Account Management",
    description: "Each client is paired with a dedicated account manager to provide personalized support, product recommendations, and ensure a seamless ordering experience.",
    color: "from-green-500 to-green-600"
  },
  {
    icon: "fa-truck-fast",
    title: "Nationwide Logistics & Delivery",
    description: "We manage a robust logistics network to ensure your orders are delivered accurately and on-time, anywhere in the UK, with flexible scheduling options.",
    color: "from-amber-500 to-amber-600"
  },
  {
    icon: "fa-chart-line",
    title: "Custom & Bulk Ordering",
    description: "We accommodate custom and large-volume orders with competitive, tiered pricing to maximize your profit margins and meet your inventory needs.",
    color: "from-red-500 to-red-600"
  },
  {
    icon: "fa-shield-halved",
    title: "Quality Assurance",
    description: "Every product in our catalog undergoes a rigorous selection and quality control process, ensuring you only receive goods that meet our high standards.",
    color: "from-emerald-500 to-emerald-600"
  },
  {
    icon: "fa-handshake",
    title: "Retailer Support & Partnership",
    description: "We see ourselves as partners in your success, offering market insights and support to help you grow your business and satisfy your customers.",
    color: "from-pink-500 to-pink-600"
  }
];

const processSteps = [
  { num: "01", title: "Consultation & Account Setup", desc: "We start by understanding your business needs and setting you up with a wholesale account." },
  { num: "02", title: "Placing Your Order", desc: "Order easily through your account manager via phone or email with your specific SKUs and quantities." },
  { num: "03", title: "Confirmation & Processing", desc: "We confirm your order and our warehouse team efficiently picks and packs your items for shipment." },
  { num: "04", title: "Delivery & Follow-Up", desc: "Your order is dispatched and delivered on schedule. We follow up to ensure your complete satisfaction." }
];
---

<Layout title="Our Services | MONE TAB LIMITED">

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-cyan-950 to-slate-900 text-white py-24 overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-cyan-500/20 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-cyan-500/15 rounded-full blur-[150px]"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-block bg-cyan-500/20 border border-cyan-400/30 text-cyan-300 text-sm font-semibold px-4 py-1.5 rounded-full mb-6">Our Services</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6">
          Comprehensive Wholesale
          <span class="block bg-gradient-to-r from-cyan-400 to-cyan-500 bg-clip-text text-transparent">Solutions</span>
        </h1>
        <p class="text-xl text-cyan-200 leading-relaxed max-w-2xl mx-auto">
          Beyond our premium products, we deliver end-to-end wholesale services that simplify your inventory, logistics and partnership needs.
        </p>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0">
      <svg class="w-full h-16 text-white" viewBox="0 0 1440 60" preserveAspectRatio="none">
        <path d="M0,40 C480,80 960,0 1440,40 L1440,60 L0,60 Z" class="fill-current"/>
      </svg>
    </div>
  </section>

  <!-- Core Services Section -->
  <section class="py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <span class="inline-block bg-cyan-100 text-cyan-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-4">What We Offer</span>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Our Services</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">Our services are tailored to meet the demands of modern retailers and businesses.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {coreServices.map((service, index) => (
          <div class="group bg-white rounded-2xl p-8 shadow-lg border border-gray-100 hover:shadow-2xl hover:border-cyan-200 transition-all duration-500 hover:-translate-y-2">
            <div class={`w-16 h-16 bg-gradient-to-br ${service.color} rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 transition-transform duration-300`}>
              <i class={`fas ${service.icon} text-2xl text-white`}></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{service.title}</h3>
            <p class="text-gray-600 leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <span class="inline-block bg-green-100 text-green-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-4">Simple Process</span>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">How It Works</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">We've streamlined our partnership process to make working with us effortless and efficient.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {processSteps.map((step, i) => (
          <div class="relative text-center group">
            {i < processSteps.length - 1 && (
              <div class="hidden lg:block absolute top-12 left-1/2 w-full h-0.5 bg-gradient-to-r from-cyan-200 to-cyan-200 z-0"></div>
            )}
            <div class="relative z-10 w-24 h-24 bg-gradient-to-br from-cyan-500 to-cyan-600 rounded-2xl flex items-center justify-center mx-auto mb-6 text-white text-3xl font-black shadow-lg shadow-cyan-500/30 group-hover:scale-110 transition-transform duration-300">
              {step.num}
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{step.title}</h3>
            <p class="text-gray-600">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative bg-gradient-to-br from-slate-950 via-cyan-900 to-slate-900 text-white py-24 overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-0 w-[400px] h-[400px] bg-cyan-500/20 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-cyan-500/20 rounded-full blur-[150px]"></div>
    </div>

    <div class="container mx-auto px-4 text-center relative z-10">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Ready to Partner With Us?</h2>
      <p class="text-xl text-cyan-200 mb-10 max-w-2xl mx-auto leading-relaxed">
        Let's discuss how our services can help you achieve your business goals. Get in touch with our expert team today.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-100 text-cyan-800 px-8 py-4 rounded-xl font-bold transition-all duration-300 hover:-translate-y-0.5 shadow-lg">
          <i class="fas fa-envelope"></i>
          Become a Partner
        </a>
        <a href="/products" class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white hover:bg-white/10 text-white px-8 py-4 rounded-xl font-bold transition-all duration-300 hover:-translate-y-0.5">
          <i class="fas fa-box"></i>
          Explore Products
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>